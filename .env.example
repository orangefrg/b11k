B11K_STRAVA_CLIENT_ID=
B11K_STRAVA_CLIENT_SECRET=
B11K_MAPBOX_TOKEN=

# Optional: set this explicitly if Strava should use a public HTTPS URL.
# B11K_STRAVA_REDIRECT_URI=https://example.com/strava/callback

B11K_PG_DATABASE=b11k_db
B11K_PG_USER=b11k
B11K_PG_PASSWORD=change-this-password
B11K_PG_HOST_PORT=25432

B11K_WEB_HOST=localhost
B11K_WEB_PROTOCOL=http
B11K_WEB_HOST_PORT=8080

# Used by docker-compose.live.yml so template changes apply on refresh.
B11K_DEV_RELOAD_TEMPLATES=true

# Narrow-screen detail pages: stats_first or map_first.
B11K_MOBILE_ACTIVITY_ORDER=stats_first
